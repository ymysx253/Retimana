    // JaName は非日本語モード時にメインラベルの下に小さく併記する（観光標識との照合用）。
    // IsAvailable=true のものだけ実際にバス情報あり（MVPは京都のみ）。
    private record Prefecture(string Key, string JaName, bool IsAvailable);
    private record PrefectureGroup(string RegionKey, Prefecture[] Prefectures);

    private static readonly PrefectureGroup[] PrefectureGroups = new[]
    {
        new PrefectureGroup("AreaSelect.Region.Hokkaido", new[]
        {
            new Prefecture("AreaSelect.Prefecture.Hokkaido", "北海道", false),
        }),
        new PrefectureGroup("AreaSelect.Region.Tohoku", new[]
        {
            new Prefecture("AreaSelect.Prefecture.Aomori",    "青森県", false),
            new Prefecture("AreaSelect.Prefecture.Iwate",     "岩手県", false),
            new Prefecture("AreaSelect.Prefecture.Miyagi",    "宮城県", false),
            new Prefecture("AreaSelect.Prefecture.Akita",     "秋田県", false),
            new Prefecture("AreaSelect.Prefecture.Yamagata",  "山形県", false),
            new Prefecture("AreaSelect.Prefecture.Fukushima", "福島県", false),
        }),
        new PrefectureGroup("AreaSelect.Region.Kanto", new[]
        {
            new Prefecture("AreaSelect.Prefecture.Ibaraki",  "茨城県",   false),
            new Prefecture("AreaSelect.Prefecture.Tochigi",  "栃木県",   false),
            new Prefecture("AreaSelect.Prefecture.Gunma",    "群馬県",   false),
            new Prefecture("AreaSelect.Prefecture.Saitama",  "埼玉県",   false),
            new Prefecture("AreaSelect.Prefecture.Chiba",    "千葉県",   false),
            new Prefecture("AreaSelect.Prefecture.Tokyo",    "東京都",   false),
            new Prefecture("AreaSelect.Prefecture.Kanagawa", "神奈川県", false),
        }),
        new PrefectureGroup("AreaSelect.Region.Chubu", new[]
        {
            new Prefecture("AreaSelect.Prefecture.Niigata",   "新潟県", false),
            new Prefecture("AreaSelect.Prefecture.Toyama",    "富山県", false),
            new Prefecture("AreaSelect.Prefecture.Ishikawa",  "石川県", false),
            new Prefecture("AreaSelect.Prefecture.Fukui",     "福井県", false),
            new Prefecture("AreaSelect.Prefecture.Yamanashi", "山梨県", false),
            new Prefecture("AreaSelect.Prefecture.Nagano",    "長野県", false),
            new Prefecture("AreaSelect.Prefecture.Gifu",      "岐阜県", false),
            new Prefecture("AreaSelect.Prefecture.Shizuoka",  "静岡県", false),
            new Prefecture("AreaSelect.Prefecture.Aichi",     "愛知県", false),
        }),
        new PrefectureGroup("AreaSelect.Region.Kinki", new[]
        {
            new Prefecture("AreaSelect.Prefecture.Mie",      "三重県",   false),
            new Prefecture("AreaSelect.Prefecture.Shiga",    "滋賀県",   false),
            new Prefecture("AreaSelect.Prefecture.Kyoto",    "京都府",   true),  // MVP: 京都府のみ有効
            new Prefecture("AreaSelect.Prefecture.Osaka",    "大阪府",   false),
            new Prefecture("AreaSelect.Prefecture.Hyogo",    "兵庫県",   false),
            new Prefecture("AreaSelect.Prefecture.Nara",     "奈良県",   false),
            new Prefecture("AreaSelect.Prefecture.Wakayama", "和歌山県", false),
        }),
        new PrefectureGroup("AreaSelect.Region.Chugoku", new[]
        {
            new Prefecture("AreaSelect.Prefecture.Tottori",   "鳥取県", false),
            new Prefecture("AreaSelect.Prefecture.Shimane",   "島根県", false),
            new Prefecture("AreaSelect.Prefecture.Okayama",   "岡山県", false),
            new Prefecture("AreaSelect.Prefecture.Hiroshima", "広島県", false),
