        }),
        new PrefectureGroup("AreaSelect.Region.Shikoku", new[]
        {
            new Prefecture("AreaSelect.Prefecture.Tokushima", "徳島県", false),
            new Prefecture("AreaSelect.Prefecture.Kagawa",    "香川県", false),
            new Prefecture("AreaSelect.Prefecture.Ehime",     "愛媛県", false),
            new Prefecture("AreaSelect.Prefecture.Kochi",     "高知県", false),
        }),
        new PrefectureGroup("AreaSelect.Region.Kyushu", new[]
        {
            new Prefecture("AreaSelect.Prefecture.Fukuoka",   "福岡県",   false),
            new Prefecture("AreaSelect.Prefecture.Saga",      "佐賀県",   false),
            new Prefecture("AreaSelect.Prefecture.Nagasaki",  "長崎県",   false),
            new Prefecture("AreaSelect.Prefecture.Kumamoto",  "熊本県",   false),
            new Prefecture("AreaSelect.Prefecture.Oita",      "大分県",   false),
            new Prefecture("AreaSelect.Prefecture.Miyazaki",  "宮崎県",   false),
            new Prefecture("AreaSelect.Prefecture.Kagoshima", "鹿児島県", false),
        }),
        new PrefectureGroup("AreaSelect.Region.Okinawa", new[]
        {
            new Prefecture("AreaSelect.Prefecture.Okinawa", "沖縄県", false),
        }),
    };

    private string BuildLabelsSvg()
    {
        var sb = new System.Text.StringBuilder();
        var isJaMode = System.Globalization.CultureInfo.CurrentUICulture.TwoLetterISOLanguageName == "ja";

        foreach (var r in Regions)
        {
            var mainLabel = System.Net.WebUtility.HtmlEncode(L[r.Key].Value);
            sb.Append($"<text x=\"{r.X}\" y=\"{r.Y}\" text-anchor=\"middle\" dominant-baseline=\"central\" class=\"area-label\">{mainLabel}</text>");

            if (!isJaMode)
            {
                var jaLabel = System.Net.WebUtility.HtmlEncode(r.JaName);
                sb.Append($"<text x=\"{r.X}\" y=\"{r.Y + SubLabelOffsetY}\" text-anchor=\"middle\" dominant-baseline=\"central\" xml:lang=\"ja\" class=\"area-label area-label-sub\">{jaLabel}</text>");
            }
        }
        return sb.ToString();
    }
}
