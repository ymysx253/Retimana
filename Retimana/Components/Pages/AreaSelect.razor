@page "/area"
@inject IStringLocalizer<SharedResources> L

@{
    var isJa = System.Globalization.CultureInfo.CurrentUICulture.TwoLetterISOLanguageName == "ja";
}

<PageTitle>@L["AreaSelect.Title"] - Retimana</PageTitle>

<div class="area-select">
    <h1 class="page-title">@L["AreaSelect.Title"]</h1>
    <svg class="japan-map" viewBox="0 0 1536 1024" preserveAspectRatio="xMidYMid meet"
         xmlns="http://www.w3.org/2000/svg" role="img" aria-label="@L["AreaSelect.MapAlt"]">
        <image href="images/japan_map.png" x="0" y="0" width="1536" height="1024" />
        <g class="area-labels">
            @((MarkupString)BuildLabelsSvg())
        </g>
    </svg>

    <div class="prefecture-list">
        @foreach (var group in PrefectureGroups)
        {
            <section class="region-group">
                <h2 class="region-heading">@L[group.RegionKey]</h2>
                <ul class="prefecture-items">
                    @foreach (var pref in group.Prefectures)
                    {
                        <li>
                            <button type="button"
                                    class="prefecture-button"
                                    disabled="@(!pref.IsAvailable)"
                                    aria-label="@(L[pref.Key].Value + (pref.IsAvailable ? "" : " (" + L["AreaSelect.ComingSoon"].Value + ")"))">
                                <span class="pref-name">@L[pref.Key]</span>
                                @if (!isJa)
                                {
                                    <span class="pref-sub" xml:lang="ja">@pref.JaName</span>
                                }
                                @if (!pref.IsAvailable)
                                {
                                    <span class="coming-soon">@L["AreaSelect.ComingSoon"]</span>
                                }
                            </button>
                        </li>
                    }
                </ul>
            </section>
        }
    </div>
</div>

@code {
    // 地図上の地方名ラベル
    private static readonly (int X, int Y, string Key, string JaName)[] Regions = new[]
    {
        (1160, 170, "AreaSelect.Region.Hokkaido", "北海道"),
        (1020, 430, "AreaSelect.Region.Tohoku",   "東北"),
        ( 980, 640, "AreaSelect.Region.Kanto",    "関東"),
        ( 800, 660, "AreaSelect.Region.Chubu",    "中部"),
        ( 660, 750, "AreaSelect.Region.Kinki",    "近畿"),
        ( 460, 710, "AreaSelect.Region.Chugoku",  "中国"),
        ( 490, 820, "AreaSelect.Region.Shikoku",  "四国"),
        ( 290, 860, "AreaSelect.Region.Kyushu",   "九州"),
        ( 250, 150, "AreaSelect.Region.Okinawa",  "沖縄"),
